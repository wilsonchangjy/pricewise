# Pricewise Phase 1 — Supabase Edge Function secrets (set via `supabase secrets set`).
# Copy to .env for local dev. NEVER commit real values — this file is the template.

# Supabase project
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=       # server-side only; used by the checker + webhook

# Telegram bot
TELEGRAM_BOT_TOKEN=              # from @BotFather
TELEGRAM_WEBHOOK_SECRET=         # random string; validated via X-Telegram-Bot-Api-Secret-Token

# Unblocker (only needed for defended brands: inditex, zara, asos, stories)
UNBLOCKER_KEY=                   # ScrapingBee API key
UNBLOCKER_PROVIDER=scrapingbee
